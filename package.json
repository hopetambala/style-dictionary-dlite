{
  "name": "style-dictionary-dlite-tokens",
  "version": "0.2.2",
  "description": "Multi-brand, multi-theme design tokens using Style Dictionary",
  "repository": {
    "type": "git",
    "url": "https://github.com/hopetambala/style-dictionary-dlite"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    "./web/*": "./dist/web/*",
    "./rn/*": {
      "types": "./dist/rn/*/index.d.ts",
      "default": "./dist/rn/*/index.js"
    },
    "./rn/*/light": {
      "types": "./dist/rn/*/light.d.ts",
      "default": "./dist/rn/*/light.js"
    },
    "./rn/*/dark": {
      "types": "./dist/rn/*/dark.d.ts",
      "default": "./dist/rn/*/dark.js"
    }
  },
  "scripts": {
    "build": "tsx ./build/index.ts",
    "clean": "rm -rf dist",
    "preview": "npm run build && vite --config preview/vite.config.ts",
    "build:preview": "npm run build && vite build --config preview/vite.config.ts",
    "test": "vitest run",
    "test:update": "vitest run --update",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@types/node": "^25.5.0",
    "commit-and-tag-version": "^12.6.1",
    "husky": "^9.1.7",
    "style-dictionary": "^5.3.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
