{
  "name": "style-dictionary-dlite-tokens",
  "version": "1.0.0",
  "description": "Multi-brand, multi-theme design tokens using Style Dictionary",
  "type": "module",
  "scripts": {
    "build": "tsx ./build.ts",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:update": "vitest run --update",
    "release": "commit-and-tag-version",
    "release:minor": "commit-and-tag-version --release-as minor",
    "release:major": "commit-and-tag-version --release-as major",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@types/node": "^25.5.0",
    "commit-and-tag-version": "^12.6.1",
    "husky": "^9.1.7",
    "style-dictionary": "^5.3.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
