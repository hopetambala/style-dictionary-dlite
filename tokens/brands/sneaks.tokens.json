{
  "sneaks": {
    "$extends": "{global}",
    "typography": {
      "$type": "fontFamily",
      "font-heading": {
        "$value": "Space Grotesk"
      },
      "font-body": {
        "$value": "Inter"
      }
    },
    "themes": {
      "default": {
        "modes": {
          "light": {
            "color": {
              "$type": "color",
              "primary": {
                "$value": "{primitive.color.neutral.1000}",
                "$extensions": { "mode": { "dark": "{primitive.color.neutral.100}" } }
              },
              "secondary": {
                "$value": "{primitive.color.neutral.600}",
                "$extensions": { "mode": { "dark": "{primitive.color.neutral.400}" } }
              },
              "brand": {
                "$value": "{primitive.color.neutral.1000}",
                "$extensions": { "mode": { "dark": "{primitive.color.neutral.100}" } }
              },
              "background": {
                "$value": "{primitive.color.neutral.100}",
                "$extensions": { "mode": { "dark": "{primitive.color.neutral.900}" } }
              },
              "foreground": {
                "$value": "{primitive.color.neutral.900}",
                "$extensions": { "mode": { "dark": "{primitive.color.neutral.100}" } }
              },
              "muted": {
                "$value": "{primitive.color.neutral.500}",
                "$extensions": { "mode": { "dark": "{primitive.color.neutral.400}" } }
              },
              "border": {
                "$value": "{primitive.color.neutral.300}",
                "$extensions": { "mode": { "dark": "{primitive.color.neutral.700}" } }
              },
              "surface-base": {
                "$value": "{primitive.color.white}",
                "$extensions": { "mode": { "dark": "{primitive.color.neutral.1000}" } }
              },
              "surface-sunken": {
                "$value": "{primitive.color.neutral.100}",
                "$extensions": { "mode": { "dark": "{primitive.color.neutral.900}" } }
              },
              "surface-raised": {
                "$value": "{primitive.color.white}",
                "$extensions": { "mode": { "dark": "{primitive.color.neutral.800}" } }
              },
              "text-primary": {
                "$value": "{primitive.color.neutral.900}",
                "$extensions": { "mode": { "dark": "{primitive.color.neutral.100}" } }
              },
              "text-secondary": {
                "$value": "{primitive.color.neutral.600}",
                "$extensions": { "mode": { "dark": "{primitive.color.neutral.400}" } }
              },
              "text-tertiary": { "$value": "{primitive.color.neutral.500}" },
              "text-on-brand": {
                "$value": "{primitive.color.white}",
                "$extensions": { "mode": { "dark": "{primitive.color.neutral.900}" } }
              },
              "text-on-primary": {
                "$value": "{primitive.color.white}",
                "$extensions": { "mode": { "dark": "{primitive.color.neutral.900}" } }
              },
              "action-primary": {
                "$value": "{primitive.color.saturated-red.900}",
                "$extensions": { "mode": { "dark": "{primitive.color.saturated-red.500}" } }
              },
              "action-primary-active": {
                "$value": "{primitive.color.saturated-red.1000}",
                "$extensions": { "mode": { "dark": "{primitive.color.saturated-red.400}" } }
              },
              "action-secondary": {
                "$value": { "colorSpace": "srgb", "components": [1, 0, 0], "alpha": 0.07, "hex": "#ff000012" },
                "$extensions": {
                  "mode": {
                    "dark": { "colorSpace": "srgb", "components": [1, 0, 0], "alpha": 0.12, "hex": "#ff00001f" }
                  }
                }
              },
              "border-subtle": {
                "$value": "{primitive.color.neutral.200}",
                "$extensions": { "mode": { "dark": "{primitive.color.neutral.800}" } }
              },
              "feedback-info": {
                "$value": "{primitive.color.blue.700}",
                "$extensions": { "mode": { "dark": "{primitive.color.blue.400}" } }
              },
              "feedback-success": {
                "$value": "{primitive.color.green.700}",
                "$extensions": { "mode": { "dark": "{primitive.color.green.400}" } }
              },
              "feedback-success-active": {
                "$value": "{primitive.color.green.800}",
                "$extensions": { "mode": { "dark": "{primitive.color.green.300}" } }
              }
            }
          },
          "dark": {}
        }
      }
    }
  }
}
