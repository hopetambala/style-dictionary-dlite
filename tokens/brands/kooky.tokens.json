                "$extensions": { "mode": { "dark": "{primitive.color.saturated-teal.400}" } }
              },
              "secondary": {
                "$value": "{primitive.color.saturated-yellow.700}",
                "$extensions": { "mode": { "dark": "{primitive.color.saturated-yellow.500}" } }
              },
              "brand": {
