{
  "semantic": {
    "color": {
      "$type": "color",
      "primary": {
        "$value": "{primitive.color.blue.500}",
        "$extensions": { "mode": { "dark": "{primitive.color.blue.400}" } }
      },
      "primary-hover": {
        "$value": "{primitive.color.blue.600}",
        "$extensions": { "mode": { "dark": "{primitive.color.blue.300}" } }
      },
      "secondary": { "$value": "{primitive.color.purple.500}" },
      "background": {
        "$value": "{primitive.color.neutral.100}",
        "$extensions": { "mode": { "dark": "{primitive.color.neutral.900}" } }
      },
      "foreground": {
        "$value": "{primitive.color.neutral.900}",
        "$extensions": { "mode": { "dark": "{primitive.color.neutral.100}" } }
      },
      "muted": {
        "$value": "{primitive.color.neutral.500}",
        "$extensions": { "mode": { "dark": "{primitive.color.neutral.400}" } }
      },
      "border": {
        "$value": "{primitive.color.neutral.300}",
        "$extensions": { "mode": { "dark": "{primitive.color.neutral.600}" } }
      },
      "success": {
        "$value": "{primitive.color.green.700}",
        "$extensions": { "mode": { "dark": "{primitive.color.green.400}" } }
      },
      "warning": {
        "$value": "{primitive.color.yellow.800}",
        "$extensions": { "mode": { "dark": "{primitive.color.yellow.500}" } }
      },
      "error": {
        "$value": "{primitive.color.red.700}",
        "$extensions": { "mode": { "dark": "{primitive.color.red.500}" } }
      },

      "surface-base": {
        "$value": "{primitive.color.white}",
        "$extensions": { "mode": { "dark": "{primitive.color.neutral.900}" } }
      },
      "surface-sunken": {
        "$value": "{primitive.color.neutral.100}",
        "$extensions": { "mode": { "dark": "{primitive.color.neutral.800}" } }
      },
      "surface-raised": {
        "$value": "{primitive.color.white}",
        "$extensions": { "mode": { "dark": "{primitive.color.neutral.750}" } }
      },
      "surface-overlay": { "$value": "{primitive.color.black}" },

      "text-primary": {
        "$value": "{primitive.color.neutral.900}",
        "$extensions": { "mode": { "dark": "{primitive.color.neutral.100}" } }
      },
      "text-secondary": {
        "$value": "{primitive.color.neutral.600}",
        "$extensions": { "mode": { "dark": "{primitive.color.neutral.300}" } }
      },
      "text-tertiary": { "$value": "{primitive.color.neutral.500}" },
      "text-on-brand": { "$value": "{primitive.color.white}" },

      "action-primary": {
        "$value": "{primitive.color.blue.500}",
        "$extensions": { "mode": { "dark": "{primitive.color.blue.400}" } }
      },
      "action-secondary": {
        "$value": "{primitive.color.neutral.100}",
        "$extensions": { "mode": { "dark": "{primitive.color.neutral.800}" } }
      },

      "feedback-info": {
        "$value": "{primitive.color.blue.600}",
        "$extensions": { "mode": { "dark": "{primitive.color.blue.400}" } }
      },
      "feedback-success": {
        "$value": "{primitive.color.green.700}",
        "$extensions": { "mode": { "dark": "{primitive.color.green.400}" } }
      },
      "feedback-warning": {
        "$value": "{primitive.color.yellow.800}",
        "$extensions": { "mode": { "dark": "{primitive.color.yellow.500}" } }
      },
      "feedback-danger": {
        "$value": "{primitive.color.red.700}",
        "$extensions": { "mode": { "dark": "{primitive.color.red.500}" } }
      }
    },
    "typography": {
      "font-heading": { "$value": "Inter", "$type": "fontFamily" },
      "font-body": { "$value": "Inter", "$type": "fontFamily" },
      "font-mono": { "$value": "JetBrains Mono", "$type": "fontFamily" },
      "size-xs": { "$value": "0.75rem", "$type": "dimension" },
      "size-sm": { "$value": "0.875rem", "$type": "dimension" },
      "size-base": { "$value": "1rem", "$type": "dimension" },
      "size-lg": { "$value": "1.125rem", "$type": "dimension" },
      "size-xl": { "$value": "1.25rem", "$type": "dimension" },
      "size-2xl": { "$value": "1.5rem", "$type": "dimension" },
      "size-3xl": { "$value": "1.875rem", "$type": "dimension" },

      "type-display-l-size": { "$value": "{primitive.dimension.font-size.1100}", "$type": "dimension" },
      "type-display-l-weight": { "$value": "{primitive.fontWeight.bold}", "$type": "fontWeight" },
      "type-display-l-line-height": { "$value": "{primitive.number.line-height.tight}", "$type": "number" },
      "type-display-l-letter-spacing": { "$value": "{primitive.dimension.letter-spacing.tight}", "$type": "dimension" },

      "type-heading-m-size": { "$value": "{primitive.dimension.font-size.700}", "$type": "dimension" },
      "type-heading-m-weight": { "$value": "{primitive.fontWeight.semibold}", "$type": "fontWeight" },
      "type-heading-m-line-height": { "$value": "{primitive.number.line-height.snug}", "$type": "number" },
      "type-heading-m-letter-spacing": { "$value": "{primitive.dimension.letter-spacing.tight}", "$type": "dimension" },

      "type-body-default-size": { "$value": "{primitive.dimension.font-size.400}", "$type": "dimension" },
      "type-body-default-weight": { "$value": "{primitive.fontWeight.regular}", "$type": "fontWeight" },
      "type-body-default-line-height": { "$value": "{primitive.number.line-height.normal}", "$type": "number" },
      "type-body-default-letter-spacing": { "$value": "{primitive.dimension.letter-spacing.normal}", "$type": "dimension" },

      "type-label-s-size": { "$value": "{primitive.dimension.font-size.200}", "$type": "dimension" },
      "type-label-s-weight": { "$value": "{primitive.fontWeight.medium}", "$type": "fontWeight" },
      "type-label-s-line-height": { "$value": "{primitive.number.line-height.normal}", "$type": "number" },
      "type-label-s-letter-spacing": { "$value": "{primitive.dimension.letter-spacing.wide}", "$type": "dimension" },

      "type-mono-m-size": { "$value": "{primitive.dimension.font-size.300}", "$type": "dimension" },
      "type-mono-m-weight": { "$value": "{primitive.fontWeight.regular}", "$type": "fontWeight" },
      "type-mono-m-line-height": { "$value": "{primitive.number.line-height.normal}", "$type": "number" },
      "type-mono-m-letter-spacing": { "$value": "{primitive.dimension.letter-spacing.normal}", "$type": "dimension" }
    },
    "spacing": {
      "$type": "dimension",
      "xs": { "$value": "0.25rem" },
      "sm": { "$value": "0.5rem" },
      "md": { "$value": "1rem" },
      "lg": { "$value": "1.5rem" },
      "xl": { "$value": "2rem" }
    },
    "border": {
      "$type": "dimension",
      "radius-none": { "$value": "{primitive.dimension.radius.0}" },
      "radius-sm": { "$value": "{primitive.dimension.radius.200}" },
      "radius-md": { "$value": "{primitive.dimension.radius.300}" },
      "radius-lg": { "$value": "0.75rem" },
      "radius-full": { "$value": "{primitive.dimension.radius.full}" }
    },
    "elevation": {
      "low": { "$value": "{primitive.shadow.200}", "$type": "shadow" },
      "high": { "$value": "{primitive.shadow.400}", "$type": "shadow" }
    }
  }
}
