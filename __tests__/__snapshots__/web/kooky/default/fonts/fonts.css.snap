/* Recoleta font faces for Kooky brand */
@font-face {
  font-family: 'Recoleta';
  src: url('./Recoleta-Regular.woff2') format('woff2'),
       url('./Recoleta-Black.ttf') format('truetype');
  font-weight: 400;
  font-style: normal;
}

@font-face {
  font-family: 'Recoleta';
  src: url('./Recoleta-Black.ttf') format('truetype');
  font-weight: 700;
  font-style: normal;
}
