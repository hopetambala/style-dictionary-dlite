.puente-hover\:text-pink-900:hover { color: var(--puente-primitive-color-pink-900); }
.puente-hover\:bg-gray-50:hover { background-color: var(--puente-primitive-color-neutral-100); }

/* ===== OPACITY ===== */
.puente-opacity-25 { opacity: var(--puente-primitive-number-opacity-20); }
.puente-opacity-50 { opacity: var(--puente-primitive-number-opacity-40); }
.puente-opacity-60 { opacity: var(--puente-primitive-number-opacity-60); }

/* ===== BORDERS ===== */
.puente-border { border: 1px solid var(--puente-semantic-color-border); }
.puente-border-t { border-top: 1px solid var(--puente-semantic-color-border); }
.puente-border-b { border-bottom: 1px solid var(--puente-semantic-color-border); }
.puente-rounded { border-radius: var(--puente-semantic-border-radius-sm); }
.puente-rounded-md { border-radius: var(--puente-semantic-border-radius-md); }
.puente-rounded-lg { border-radius: var(--puente-semantic-border-radius-lg); }
.puente-rounded-full { border-radius: var(--puente-semantic-border-radius-full); }
.puente-shadow-sm { box-shadow: var(--puente-semantic-elevation-low); }
.puente-shadow-md { box-shadow: var(--puente-semantic-elevation-medium); }
.puente-shadow-lg { box-shadow: var(--puente-semantic-elevation-high); }

/* ===== COMPONENTS — Buttons ===== */
.puente-btn {
  display: inline-flex; align-items: center; justify-content: center;
  font-weight: var(--puente-primitive-fontWeight-medium);
  border-radius: var(--puente-semantic-border-radius-lg);
  padding: var(--puente-semantic-spacing-2) var(--puente-semantic-spacing-4);
  transition: background-color var(--puente-semantic-duration-fast) ease, color var(--puente-semantic-duration-fast) ease, opacity var(--puente-semantic-duration-fast) ease;
  cursor: pointer; white-space: nowrap;
}
.puente-btn:disabled { opacity: 0.5; cursor: not-allowed; }
.puente-btn-primary { background-color: var(--puente-semantic-color-action-primary); color: var(--puente-semantic-color-text-on-brand); }
.puente-btn-primary:hover:not(:disabled) { background-color: var(--puente-primitive-color-blue-700); }
.puente-btn-success { background-color: var(--puente-semantic-color-feedback-success); color: var(--puente-semantic-color-text-on-brand); }
.puente-btn-success:hover:not(:disabled) { background-color: var(--puente-primitive-color-green-700); }
.puente-btn-danger { background-color: var(--puente-semantic-color-feedback-danger); color: var(--puente-semantic-color-text-on-brand); }
.puente-btn-danger:hover:not(:disabled) { background-color: var(--puente-primitive-color-red-800); }
.puente-btn-secondary { background-color: var(--puente-semantic-color-action-secondary); color: var(--puente-semantic-color-text-primary); }
.puente-btn-secondary:hover:not(:disabled) { background-color: var(--puente-primitive-color-neutral-300); }
.puente-btn-sm { font-size: var(--puente-semantic-typography-size-sm); padding: var(--puente-semantic-spacing-1) var(--puente-semantic-spacing-3); }
.puente-btn-lg { padding: var(--puente-semantic-spacing-3) var(--puente-semantic-spacing-6); }
.puente-btn-link { background: none; padding: 0; text-decoration: underline; }
.puente-btn-link:hover { opacity: 0.8; }

/* ===== COMPONENTS — Inputs ===== */
.puente-input {
  border: 1px solid var(--puente-semantic-color-border);
  border-radius: var(--puente-semantic-border-radius-lg);
  padding: var(--puente-semantic-spacing-2) var(--puente-semantic-spacing-3);
  background-color: var(--puente-semantic-color-surface-base);
  color: var(--puente-semantic-color-text-primary);
  width: 100%;
  transition: border-color var(--puente-semantic-duration-fast) ease, box-shadow var(--puente-semantic-duration-fast) ease;
}
.puente-input:focus { outline: none; border-color: var(--puente-semantic-color-action-primary); box-shadow: 0 0 0 2px color-mix(in srgb, var(--puente-semantic-color-action-primary) 30%, transparent); }
.puente-input-lg { padding: var(--puente-semantic-spacing-3) var(--puente-semantic-spacing-4); }

/* ===== COMPONENTS — Badges ===== */
.puente-badge {
  display: inline-flex; align-items: center;
  font-size: var(--puente-semantic-typography-size-xs);
  font-weight: var(--puente-primitive-fontWeight-medium);
  padding: var(--puente-semantic-spacing-2xs) var(--puente-semantic-spacing-2);
  border-radius: var(--puente-semantic-border-radius-full);
}
.puente-badge-success { background-color: var(--puente-primitive-color-green-200); color: var(--puente-primitive-color-green-800); }
.puente-badge-warning { background-color: var(--puente-primitive-color-yellow-200); color: var(--puente-primitive-color-yellow-800); }
.puente-badge-danger { background-color: var(--puente-primitive-color-red-200); color: var(--puente-primitive-color-red-800); }
.puente-badge-neutral { background-color: var(--puente-primitive-color-neutral-200); color: var(--puente-primitive-color-neutral-600); }
.puente-badge-info { background-color: var(--puente-primitive-color-blue-200); color: var(--puente-primitive-color-blue-800); }

/* ===== COMPONENTS — Cards ===== */
.puente-card {
  border: 1px solid var(--puente-semantic-color-border);
  border-radius: var(--puente-semantic-border-radius-lg);
  padding: var(--puente-semantic-spacing-md);
  background-color: var(--puente-semantic-color-surface-base);
  transition: background-color var(--puente-semantic-duration-fast) ease;
}
.puente-card-interactive:hover { background-color: var(--puente-semantic-color-surface-sunken); }

/* ===== COMPONENTS — Tables ===== */
.puente-table { width: 100%; font-size: var(--puente-semantic-typography-size-sm); border-collapse: collapse; }
.puente-table th, .puente-table td { border: 1px solid var(--puente-semantic-color-border); padding: var(--puente-semantic-spacing-2); }
.puente-table th { background-color: var(--puente-semantic-color-surface-sunken); text-align: left; font-weight: var(--puente-primitive-fontWeight-semibold); }
.puente-table th.puente-text-center, .puente-table td.puente-text-center { text-align: center; }

/* ===== COMPONENTS — Toggle Button ===== */
.puente-toggle-btn {
  width: 2rem; height: 2rem;
  border-radius: var(--puente-semantic-border-radius-sm);
  font-size: var(--puente-semantic-typography-size-sm);
  font-weight: var(--puente-primitive-fontWeight-medium);
  transition: background-color var(--puente-semantic-duration-fast) ease, color var(--puente-semantic-duration-fast) ease;
  display: inline-flex; align-items: center; justify-content: center;
}
.puente-toggle-btn-on { background-color: var(--puente-semantic-color-action-primary); color: var(--puente-semantic-color-text-on-brand); }
.puente-toggle-btn-off { background-color: var(--puente-primitive-color-neutral-200); color: var(--puente-primitive-color-neutral-400); }
.puente-toggle-btn-off:hover { background-color: var(--puente-primitive-color-neutral-300); }

/* ===== TRANSITIONS ===== */
.puente-transition-colors { transition: background-color var(--puente-semantic-duration-fast) ease, color var(--puente-semantic-duration-fast) ease, border-color var(--puente-semantic-duration-fast) ease; }

/* ===== INTERACTIVE STATES ===== */
.puente-disabled\:opacity-50:disabled { opacity: 0.5; }
.puente-disabled\:opacity-25:disabled { opacity: 0.25; }
.puente-disabled\:cursor-not-allowed:disabled { cursor: not-allowed; }
.puente-focus-ring:focus { outline: none; border-color: var(--puente-semantic-color-action-primary); box-shadow: 0 0 0 2px color-mix(in srgb, var(--puente-semantic-color-action-primary) 30%, transparent); }

/* ===== RESPONSIVE ===== */
@media (min-width: 640px) {
  .puente-sm\:grid-cols-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .puente-sm\:grid-cols-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
}
@media (min-width: 768px) {
  .puente-md\:grid-cols-4 { grid-template-columns: repeat(4, minmax(0, 1fr)); }
}
@media (min-width: 1024px) {
  .puente-lg\:flex-row { flex-direction: row; }
  .puente-lg\:w-72 { width: 18rem; }
  .puente-lg\:flex-shrink-0 { flex-shrink: 0; }
  .puente-lg\:max-h-\[70vh\] { max-height: 70vh; }
  .puente-lg\:overflow-y-auto { overflow-y: auto; }
}

