.cl-dlite-font-mono { font-family: var(--tk-dlite-semantic-typography-font-mono), monospace; }
.cl-dlite-text-100 { font-size: var(--tk-dlite-semantic-typography-size-100); }
.cl-dlite-text-200 { font-size: var(--tk-dlite-semantic-typography-size-200); }
.cl-dlite-text-300 { font-size: var(--tk-dlite-semantic-typography-size-300); }
.cl-dlite-text-400 { font-size: var(--tk-dlite-semantic-typography-size-400); }
.cl-dlite-text-500 { font-size: var(--tk-dlite-semantic-typography-size-500); }
.cl-dlite-text-600 { font-size: var(--tk-dlite-semantic-typography-size-600); }
.cl-dlite-text-700 { font-size: var(--tk-dlite-semantic-typography-size-700); }
.cl-dlite-text-800 { font-size: var(--tk-dlite-semantic-typography-size-800); }
.cl-dlite-text-900 { font-size: var(--tk-dlite-semantic-typography-size-900); }
.cl-dlite-text-1000 { font-size: var(--tk-dlite-semantic-typography-size-1000); }

/* ===== SEMANTIC COLORS ===== */
.cl-dlite-text-primary { color: var(--tk-dlite-semantic-color-text-primary); }
.cl-dlite-text-secondary { color: var(--tk-dlite-semantic-color-text-secondary); }
.cl-dlite-text-tertiary { color: var(--tk-dlite-semantic-color-text-tertiary); }
.cl-dlite-text-on-brand { color: var(--tk-dlite-semantic-color-text-on-brand); }
.cl-dlite-text-muted { color: var(--tk-dlite-semantic-color-muted); }
.cl-dlite-text-success { color: var(--tk-dlite-semantic-color-feedback-success); }
.cl-dlite-text-warning { color: var(--tk-dlite-semantic-color-feedback-warning); }
.cl-dlite-text-danger { color: var(--tk-dlite-semantic-color-feedback-danger); }
.cl-dlite-text-info { color: var(--tk-dlite-semantic-color-feedback-info); }
.cl-dlite-bg-base { background-color: var(--tk-dlite-semantic-color-surface-base); }
.cl-dlite-bg-sunken { background-color: var(--tk-dlite-semantic-color-surface-sunken); }
.cl-dlite-bg-raised { background-color: var(--tk-dlite-semantic-color-surface-raised); }
.cl-dlite-bg-overlay { background-color: var(--tk-dlite-semantic-color-surface-overlay); }
.cl-dlite-bg-primary { background-color: var(--tk-dlite-semantic-color-action-primary); }
.cl-dlite-bg-secondary { background-color: var(--tk-dlite-semantic-color-action-secondary); }

/* ===== BORDERS & RADIUS ===== */
.cl-dlite-border { border: 1px solid var(--tk-dlite-semantic-color-border); }
.cl-dlite-border-t { border-top: 1px solid var(--tk-dlite-semantic-color-border); }
.cl-dlite-border-b { border-bottom: 1px solid var(--tk-dlite-semantic-color-border); }
.cl-dlite-rounded { border-radius: var(--tk-dlite-semantic-border-radius-sm); }
.cl-dlite-rounded-md { border-radius: var(--tk-dlite-semantic-border-radius-md); }
.cl-dlite-rounded-lg { border-radius: var(--tk-dlite-semantic-border-radius-lg); }
.cl-dlite-rounded-full { border-radius: var(--tk-dlite-semantic-border-radius-full); }

/* ===== SHADOWS ===== */
.cl-dlite-shadow-sm { box-shadow: var(--tk-dlite-semantic-elevation-low); }
.cl-dlite-shadow-md { box-shadow: var(--tk-dlite-semantic-elevation-medium); }
.cl-dlite-shadow-lg { box-shadow: var(--tk-dlite-semantic-elevation-high); }

/* ===== TRANSITIONS ===== */
.cl-dlite-transition-colors { transition: background-color var(--tk-dlite-semantic-duration-fast) ease, color var(--tk-dlite-semantic-duration-fast) ease, border-color var(--tk-dlite-semantic-duration-fast) ease; }

/* ===== INTERACTIVE STATES ===== */
.cl-dlite-disabled\:opacity-50:disabled { opacity: 0.5; }
.cl-dlite-disabled\:opacity-25:disabled { opacity: 0.25; }
.cl-dlite-disabled\:cursor-not-allowed:disabled { cursor: not-allowed; }
.cl-dlite-focus-ring:focus { outline: none; border-color: var(--tk-dlite-semantic-color-action-primary); box-shadow: 0 0 0 2px color-mix(in srgb, var(--tk-dlite-semantic-color-action-primary) 30%, transparent); }

/* ===== RESPONSIVE ===== */
@media (min-width: 640px) {
  .cl-dlite-sm\:grid-cols-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .cl-dlite-sm\:grid-cols-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
}
@media (min-width: 768px) {
  .cl-dlite-md\:grid-cols-4 { grid-template-columns: repeat(4, minmax(0, 1fr)); }
}
@media (min-width: 1024px) {
  .cl-dlite-lg\:flex-row { flex-direction: row; }
  .cl-dlite-lg\:w-72 { width: 18rem; }
  .cl-dlite-lg\:flex-shrink-0 { flex-shrink: 0; }
  .cl-dlite-lg\:max-h-\[70vh\] { max-height: 70vh; }
  .cl-dlite-lg\:overflow-y-auto { overflow-y: auto; }
}

