.cl-dlite-sem-text-100 { font-size: var(--tk-dlite-semantic-typography-size-100); }
.cl-dlite-sem-text-200 { font-size: var(--tk-dlite-semantic-typography-size-200); }
.cl-dlite-sem-text-300 { font-size: var(--tk-dlite-semantic-typography-size-300); }
.cl-dlite-sem-text-400 { font-size: var(--tk-dlite-semantic-typography-size-400); }
.cl-dlite-sem-text-500 { font-size: var(--tk-dlite-semantic-typography-size-500); }
.cl-dlite-sem-text-600 { font-size: var(--tk-dlite-semantic-typography-size-600); }
.cl-dlite-sem-text-700 { font-size: var(--tk-dlite-semantic-typography-size-700); }
.cl-dlite-sem-text-800 { font-size: var(--tk-dlite-semantic-typography-size-800); }
.cl-dlite-sem-text-900 { font-size: var(--tk-dlite-semantic-typography-size-900); }
.cl-dlite-sem-text-1000 { font-size: var(--tk-dlite-semantic-typography-size-1000); }

/* ===== SEMANTIC COLORS ===== */
.cl-dlite-sem-text-primary { color: var(--tk-dlite-semantic-color-text-primary); }
.cl-dlite-sem-text-secondary { color: var(--tk-dlite-semantic-color-text-secondary); }
.cl-dlite-sem-text-tertiary { color: var(--tk-dlite-semantic-color-text-tertiary); }
.cl-dlite-sem-text-on-brand { color: var(--tk-dlite-semantic-color-text-on-brand); }
.cl-dlite-sem-text-muted { color: var(--tk-dlite-semantic-color-muted); }
.cl-dlite-sem-text-success { color: var(--tk-dlite-semantic-color-feedback-success); }
.cl-dlite-sem-text-warning { color: var(--tk-dlite-semantic-color-feedback-warning); }
.cl-dlite-sem-text-danger { color: var(--tk-dlite-semantic-color-feedback-danger); }
.cl-dlite-sem-text-info { color: var(--tk-dlite-semantic-color-feedback-info); }
.cl-dlite-sem-bg-base { background-color: var(--tk-dlite-semantic-color-surface-base); }
.cl-dlite-sem-bg-sunken { background-color: var(--tk-dlite-semantic-color-surface-sunken); }
.cl-dlite-sem-bg-raised { background-color: var(--tk-dlite-semantic-color-surface-raised); }
.cl-dlite-sem-bg-overlay { background-color: var(--tk-dlite-semantic-color-surface-overlay); }
.cl-dlite-sem-bg-primary { background-color: var(--tk-dlite-semantic-color-action-primary); }
.cl-dlite-sem-bg-secondary { background-color: var(--tk-dlite-semantic-color-action-secondary); }

/* ===== BORDERS & RADIUS ===== */
.cl-dlite-sem-border { border: 1px solid var(--tk-dlite-semantic-color-border); }
.cl-dlite-sem-border-t { border-top: 1px solid var(--tk-dlite-semantic-color-border); }
.cl-dlite-sem-border-r { border-right: 1px solid var(--tk-dlite-semantic-color-border); }
.cl-dlite-sem-border-b { border-bottom: 1px solid var(--tk-dlite-semantic-color-border); }
.cl-dlite-sem-border-l { border-left: 1px solid var(--tk-dlite-semantic-color-border); }
.cl-dlite-sem-rounded { border-radius: var(--tk-dlite-semantic-border-radius-sm); }
.cl-dlite-sem-rounded-md { border-radius: var(--tk-dlite-semantic-border-radius-md); }
.cl-dlite-sem-rounded-lg { border-radius: var(--tk-dlite-semantic-border-radius-lg); }
.cl-dlite-sem-rounded-full { border-radius: var(--tk-dlite-semantic-border-radius-full); }

/* ===== SHADOWS ===== */
.cl-dlite-sem-shadow-sm { box-shadow: var(--tk-dlite-semantic-elevation-low); }
.cl-dlite-sem-shadow-md { box-shadow: var(--tk-dlite-semantic-elevation-medium); }
.cl-dlite-sem-shadow-lg { box-shadow: var(--tk-dlite-semantic-elevation-high); }

/* ===== TRANSITIONS ===== */
.cl-dlite-sem-transition-colors { transition: background-color var(--tk-dlite-semantic-duration-fast) ease, color var(--tk-dlite-semantic-duration-fast) ease, border-color var(--tk-dlite-semantic-duration-fast) ease; }

/* ===== INTERACTIVE STATES ===== */
.cl-dlite-sem-focus-ring:focus { outline: none; border-color: var(--tk-dlite-semantic-color-action-primary); box-shadow: 0 0 0 2px color-mix(in srgb, var(--tk-dlite-semantic-color-action-primary) 30%, transparent); }

