/* ===== BUTTONS ===== */
.survivor-btn {
  display: inline-flex; align-items: center; justify-content: center;
  font-weight: var(--survivor-primitive-fontWeight-medium);
  border-radius: var(--survivor-semantic-border-radius-lg);
  padding: var(--survivor-semantic-spacing-200) var(--survivor-semantic-spacing-400);
  transition: background-color var(--survivor-semantic-duration-fast) ease, color var(--survivor-semantic-duration-fast) ease, opacity var(--survivor-semantic-duration-fast) ease;
  cursor: pointer; white-space: nowrap;
}
.survivor-btn:disabled { opacity: 0.5; cursor: not-allowed; }
.survivor-btn-primary { background-color: var(--survivor-semantic-color-action-primary); color: var(--survivor-semantic-color-text-on-brand); }
.survivor-btn-primary:not(:disabled):active { background-color: var(--survivor-primitive-color-blue-700); }
.survivor-btn-success { background-color: var(--survivor-semantic-color-feedback-success); color: var(--survivor-semantic-color-text-on-brand); }
.survivor-btn-success:not(:disabled):active { background-color: var(--survivor-primitive-color-green-700); }
.survivor-btn-danger { background-color: var(--survivor-semantic-color-feedback-danger); color: var(--survivor-semantic-color-text-on-brand); }
.survivor-btn-danger:not(:disabled):active { background-color: var(--survivor-primitive-color-red-800); }
.survivor-btn-secondary { background-color: var(--survivor-semantic-color-action-secondary); color: var(--survivor-semantic-color-text-primary); }
.survivor-btn-secondary:not(:disabled):active { background-color: var(--survivor-primitive-color-neutral-300); }
.survivor-btn-sm { font-size: var(--survivor-semantic-typography-size-300); padding: var(--survivor-semantic-spacing-100) var(--survivor-semantic-spacing-300); }
.survivor-btn-lg { padding: var(--survivor-semantic-spacing-300) var(--survivor-semantic-spacing-600); }
.survivor-btn-link { background: none; padding: 0; text-decoration: underline; }

/* ===== INPUTS ===== */
.survivor-input {
  border: 1px solid var(--survivor-semantic-color-border);
  border-radius: var(--survivor-semantic-border-radius-lg);
  padding: var(--survivor-semantic-spacing-200) var(--survivor-semantic-spacing-300);
  background-color: var(--survivor-semantic-color-surface-base);
  color: var(--survivor-semantic-color-text-primary);
  width: 100%;
  transition: border-color var(--survivor-semantic-duration-fast) ease, box-shadow var(--survivor-semantic-duration-fast) ease;
}
.survivor-input:focus { outline: none; border-color: var(--survivor-semantic-color-action-primary); box-shadow: 0 0 0 2px color-mix(in srgb, var(--survivor-semantic-color-action-primary) 30%, transparent); }
.survivor-input-lg { padding: var(--survivor-semantic-spacing-300) var(--survivor-semantic-spacing-400); }

/* ===== BADGES ===== */
.survivor-badge {
  display: inline-flex; align-items: center;
  font-size: var(--survivor-semantic-typography-size-200);
  font-weight: var(--survivor-primitive-fontWeight-medium);
  padding: var(--survivor-semantic-spacing-xxs) var(--survivor-semantic-spacing-200);
  border-radius: var(--survivor-semantic-border-radius-full);
}
.survivor-badge-success { background-color: var(--survivor-primitive-color-green-200); color: var(--survivor-primitive-color-green-800); }
.survivor-badge-warning { background-color: var(--survivor-primitive-color-yellow-200); color: var(--survivor-primitive-color-yellow-800); }
.survivor-badge-danger { background-color: var(--survivor-primitive-color-red-200); color: var(--survivor-primitive-color-red-800); }
.survivor-badge-neutral { background-color: var(--survivor-primitive-color-neutral-200); color: var(--survivor-primitive-color-neutral-600); }
.survivor-badge-info { background-color: var(--survivor-primitive-color-blue-200); color: var(--survivor-primitive-color-blue-800); }

/* ===== CARDS ===== */
.survivor-card {
  border: 1px solid var(--survivor-semantic-color-border);
  border-radius: var(--survivor-semantic-border-radius-lg);
  padding: var(--survivor-semantic-spacing-md);
  background-color: var(--survivor-semantic-color-surface-base);
  transition: background-color var(--survivor-semantic-duration-fast) ease;
}

/* ===== TABLES ===== */
.survivor-table { width: 100%; font-size: var(--survivor-semantic-typography-size-300); border-collapse: collapse; }
.survivor-table th, .survivor-table td { border: 1px solid var(--survivor-semantic-color-border); padding: var(--survivor-semantic-spacing-200); }
.survivor-table th { background-color: var(--survivor-semantic-color-surface-sunken); text-align: left; font-weight: var(--survivor-primitive-fontWeight-semibold); }
.survivor-table th.survivor-text-center, .survivor-table td.survivor-text-center { text-align: center; }

/* ===== TOGGLE BUTTONS ===== */
.survivor-toggle-btn {
  width: 2rem; height: 2rem;
  border-radius: var(--survivor-semantic-border-radius-sm);
  font-size: var(--survivor-semantic-typography-size-300);
  font-weight: var(--survivor-primitive-fontWeight-medium);
  transition: background-color var(--survivor-semantic-duration-fast) ease, color var(--survivor-semantic-duration-fast) ease;
  display: inline-flex; align-items: center; justify-content: center;
}
.survivor-toggle-btn-on { background-color: var(--survivor-semantic-color-action-primary); color: var(--survivor-semantic-color-text-on-brand); }
.survivor-toggle-btn-off { background-color: var(--survivor-primitive-color-neutral-200); color: var(--survivor-primitive-color-neutral-400); }

