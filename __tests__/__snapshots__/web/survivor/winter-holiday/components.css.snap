.cl-dlite-badge-danger { background-color: var(--tk-dlite-primitive-color-red-200); color: var(--tk-dlite-primitive-color-red-800); }
.cl-dlite-badge-neutral { background-color: var(--tk-dlite-primitive-color-neutral-200); color: var(--tk-dlite-primitive-color-neutral-600); }
