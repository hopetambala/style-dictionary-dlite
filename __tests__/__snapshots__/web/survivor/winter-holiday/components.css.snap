  transition: background-color var(--tk-dlite-semantic-duration-fast) ease, color var(--tk-dlite-semantic-duration-fast) ease, opacity var(--tk-dlite-semantic-duration-fast) ease;
  cursor: pointer; white-space: nowrap;
}
.cl-dlite-btn:disabled { opacity: 0.5; cursor: not-allowed; }
.cl-dlite-btn-primary { background-color: var(--tk-dlite-semantic-color-action-primary); color: var(--tk-dlite-semantic-color-text-on-brand); }
.cl-dlite-btn-primary:not(:disabled):active { background-color: var(--tk-dlite-semantic-color-action-primary-active); }
.cl-dlite-btn-success { background-color: var(--tk-dlite-semantic-color-feedback-success); color: var(--tk-dlite-semantic-color-text-on-brand); }
.cl-dlite-btn-success:not(:disabled):active { background-color: var(--tk-dlite-semantic-color-feedback-success-active); }
.cl-dlite-btn-danger { background-color: var(--tk-dlite-semantic-color-feedback-danger); color: var(--tk-dlite-semantic-color-text-on-brand); }
.cl-dlite-btn-danger:not(:disabled):active { background-color: var(--tk-dlite-semantic-color-feedback-danger-active); }
.cl-dlite-btn-secondary { background-color: var(--tk-dlite-semantic-color-action-secondary); color: var(--tk-dlite-semantic-color-text-primary); }
.cl-dlite-btn-secondary:not(:disabled):active { background-color: var(--tk-dlite-semantic-color-action-secondary-active); }
.cl-dlite-btn-sm { font-size: var(--tk-dlite-semantic-typography-size-300); padding: var(--tk-dlite-semantic-spacing-100) var(--tk-dlite-semantic-spacing-300); }
.cl-dlite-btn-lg { padding: var(--tk-dlite-semantic-spacing-300) var(--tk-dlite-semantic-spacing-600); }
.cl-dlite-btn-link { background: none; padding: 0; text-decoration: underline; }

/* ===== INPUTS ===== */
.cl-dlite-input {
  border: 1px solid var(--tk-dlite-semantic-color-border);
  border-radius: var(--tk-dlite-semantic-border-radius-lg);
  padding: var(--tk-dlite-semantic-spacing-200) var(--tk-dlite-semantic-spacing-300);
  background-color: var(--tk-dlite-semantic-color-surface-base);
  color: var(--tk-dlite-semantic-color-text-primary);
  width: 100%;
  transition: border-color var(--tk-dlite-semantic-duration-fast) ease, box-shadow var(--tk-dlite-semantic-duration-fast) ease;
}
.cl-dlite-input:focus { outline: none; border-color: var(--tk-dlite-semantic-color-action-primary); box-shadow: 0 0 0 2px color-mix(in srgb, var(--tk-dlite-semantic-color-action-primary) 30%, transparent); }
.cl-dlite-input-lg { padding: var(--tk-dlite-semantic-spacing-300) var(--tk-dlite-semantic-spacing-400); }

/* ===== BADGES ===== */
.cl-dlite-badge {
  display: inline-flex; align-items: center;
  font-size: var(--tk-dlite-semantic-typography-size-200);
