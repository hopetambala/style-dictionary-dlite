.hover\:text-pink-300:hover { color: var(--survivor-primitive-color-pink-300); }
.hover\:bg-pink-400:hover { background-color: var(--survivor-primitive-color-pink-400); }
.hover\:text-pink-400:hover { color: var(--survivor-primitive-color-pink-400); }
.hover\:bg-pink-500:hover { background-color: var(--survivor-primitive-color-pink-500); }
.hover\:text-pink-500:hover { color: var(--survivor-primitive-color-pink-500); }
.hover\:bg-pink-600:hover { background-color: var(--survivor-primitive-color-pink-600); }
.hover\:text-pink-600:hover { color: var(--survivor-primitive-color-pink-600); }
.hover\:bg-pink-700:hover { background-color: var(--survivor-primitive-color-pink-700); }
.hover\:text-pink-700:hover { color: var(--survivor-primitive-color-pink-700); }
.hover\:bg-pink-800:hover { background-color: var(--survivor-primitive-color-pink-800); }
.hover\:text-pink-800:hover { color: var(--survivor-primitive-color-pink-800); }
.hover\:bg-pink-900:hover { background-color: var(--survivor-primitive-color-pink-900); }
.hover\:text-pink-900:hover { color: var(--survivor-primitive-color-pink-900); }
.hover\:bg-gray-50:hover { background-color: var(--survivor-primitive-color-neutral-100); }

/* ===== OPACITY ===== */
.opacity-25 { opacity: var(--survivor-primitive-number-opacity-20); }
.opacity-50 { opacity: var(--survivor-primitive-number-opacity-40); }
.opacity-60 { opacity: var(--survivor-primitive-number-opacity-60); }

/* ===== BORDERS ===== */
.border { border: 1px solid var(--survivor-semantic-color-border); }
.border-t { border-top: 1px solid var(--survivor-semantic-color-border); }
.border-b { border-bottom: 1px solid var(--survivor-semantic-color-border); }
.rounded { border-radius: var(--survivor-semantic-border-radius-sm); }
.rounded-md { border-radius: var(--survivor-semantic-border-radius-md); }
.rounded-lg { border-radius: var(--survivor-semantic-border-radius-lg); }
.rounded-full { border-radius: var(--survivor-semantic-border-radius-full); }
.shadow-sm { box-shadow: var(--survivor-semantic-elevation-low); }
.shadow-md { box-shadow: var(--survivor-semantic-elevation-medium); }
.shadow-lg { box-shadow: var(--survivor-semantic-elevation-high); }

/* ===== COMPONENTS — Buttons ===== */
.btn {
  display: inline-flex; align-items: center; justify-content: center;
  font-weight: var(--survivor-primitive-fontWeight-medium);
  border-radius: var(--survivor-semantic-border-radius-lg);
  padding: var(--survivor-semantic-spacing-2) var(--survivor-semantic-spacing-4);
  transition: background-color var(--survivor-semantic-duration-fast) ease, color var(--survivor-semantic-duration-fast) ease, opacity var(--survivor-semantic-duration-fast) ease;
  cursor: pointer; white-space: nowrap;
}
.btn:disabled { opacity: 0.5; cursor: not-allowed; }
.btn-primary { background-color: var(--survivor-semantic-color-action-primary); color: var(--survivor-semantic-color-text-on-brand); }
.btn-primary:hover:not(:disabled) { background-color: var(--survivor-primitive-color-blue-700); }
.btn-success { background-color: var(--survivor-semantic-color-feedback-success); color: var(--survivor-semantic-color-text-on-brand); }
.btn-success:hover:not(:disabled) { background-color: var(--survivor-primitive-color-green-700); }
.btn-danger { background-color: var(--survivor-semantic-color-feedback-danger); color: var(--survivor-semantic-color-text-on-brand); }
.btn-danger:hover:not(:disabled) { background-color: var(--survivor-primitive-color-red-800); }
.btn-secondary { background-color: var(--survivor-semantic-color-action-secondary); color: var(--survivor-semantic-color-text-primary); }
.btn-secondary:hover:not(:disabled) { background-color: var(--survivor-primitive-color-neutral-300); }
.btn-sm { font-size: var(--survivor-semantic-typography-size-sm); padding: var(--survivor-semantic-spacing-1) var(--survivor-semantic-spacing-3); }
.btn-lg { padding: var(--survivor-semantic-spacing-3) var(--survivor-semantic-spacing-6); }
.btn-link { background: none; padding: 0; text-decoration: underline; }
.btn-link:hover { opacity: 0.8; }

/* ===== COMPONENTS — Inputs ===== */
.input {
  border: 1px solid var(--survivor-semantic-color-border);
  border-radius: var(--survivor-semantic-border-radius-lg);
  padding: var(--survivor-semantic-spacing-2) var(--survivor-semantic-spacing-3);
  background-color: var(--survivor-semantic-color-surface-base);
  color: var(--survivor-semantic-color-text-primary);
  width: 100%;
  transition: border-color var(--survivor-semantic-duration-fast) ease, box-shadow var(--survivor-semantic-duration-fast) ease;
}
.input:focus { outline: none; border-color: var(--survivor-semantic-color-action-primary); box-shadow: 0 0 0 2px color-mix(in srgb, var(--survivor-semantic-color-action-primary) 30%, transparent); }
.input-lg { padding: var(--survivor-semantic-spacing-3) var(--survivor-semantic-spacing-4); }

/* ===== COMPONENTS — Badges ===== */
.badge {
  display: inline-flex; align-items: center;
  font-size: var(--survivor-semantic-typography-size-xs);
  font-weight: var(--survivor-primitive-fontWeight-medium);
  padding: var(--survivor-semantic-spacing-2xs) var(--survivor-semantic-spacing-2);
  border-radius: var(--survivor-semantic-border-radius-full);
}
.badge-success { background-color: var(--survivor-primitive-color-green-200); color: var(--survivor-primitive-color-green-800); }
.badge-warning { background-color: var(--survivor-primitive-color-yellow-200); color: var(--survivor-primitive-color-yellow-800); }
.badge-danger { background-color: var(--survivor-primitive-color-red-200); color: var(--survivor-primitive-color-red-800); }
.badge-neutral { background-color: var(--survivor-primitive-color-neutral-200); color: var(--survivor-primitive-color-neutral-600); }
.badge-info { background-color: var(--survivor-primitive-color-blue-200); color: var(--survivor-primitive-color-blue-800); }

/* ===== COMPONENTS — Cards ===== */
.card {
  border: 1px solid var(--survivor-semantic-color-border);
  border-radius: var(--survivor-semantic-border-radius-lg);
  padding: var(--survivor-semantic-spacing-md);
  background-color: var(--survivor-semantic-color-surface-base);
  transition: background-color var(--survivor-semantic-duration-fast) ease;
}
.card-interactive:hover { background-color: var(--survivor-semantic-color-surface-sunken); }

/* ===== COMPONENTS — Tables ===== */
.table { width: 100%; font-size: var(--survivor-semantic-typography-size-sm); border-collapse: collapse; }
.table th, .table td { border: 1px solid var(--survivor-semantic-color-border); padding: var(--survivor-semantic-spacing-2); }
.table th { background-color: var(--survivor-semantic-color-surface-sunken); text-align: left; font-weight: var(--survivor-primitive-fontWeight-semibold); }
.table th.text-center, .table td.text-center { text-align: center; }

/* ===== COMPONENTS — Toggle Button ===== */
.toggle-btn {
  width: 2rem; height: 2rem;
  border-radius: var(--survivor-semantic-border-radius-sm);
  font-size: var(--survivor-semantic-typography-size-sm);
  font-weight: var(--survivor-primitive-fontWeight-medium);
  transition: background-color var(--survivor-semantic-duration-fast) ease, color var(--survivor-semantic-duration-fast) ease;
  display: inline-flex; align-items: center; justify-content: center;
}
.toggle-btn-on { background-color: var(--survivor-semantic-color-action-primary); color: var(--survivor-semantic-color-text-on-brand); }
.toggle-btn-off { background-color: var(--survivor-primitive-color-neutral-200); color: var(--survivor-primitive-color-neutral-400); }
.toggle-btn-off:hover { background-color: var(--survivor-primitive-color-neutral-300); }

/* ===== TRANSITIONS ===== */
.transition-colors { transition: background-color var(--survivor-semantic-duration-fast) ease, color var(--survivor-semantic-duration-fast) ease, border-color var(--survivor-semantic-duration-fast) ease; }

/* ===== INTERACTIVE STATES ===== */
.disabled\:opacity-50:disabled { opacity: 0.5; }
.disabled\:opacity-25:disabled { opacity: 0.25; }
.disabled\:cursor-not-allowed:disabled { cursor: not-allowed; }
.focus-ring:focus { outline: none; border-color: var(--survivor-semantic-color-action-primary); box-shadow: 0 0 0 2px color-mix(in srgb, var(--survivor-semantic-color-action-primary) 30%, transparent); }

/* ===== RESPONSIVE ===== */
@media (min-width: 640px) {
  .sm\:grid-cols-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .sm\:grid-cols-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
}
@media (min-width: 768px) {
  .md\:grid-cols-4 { grid-template-columns: repeat(4, minmax(0, 1fr)); }
}
@media (min-width: 1024px) {
  .lg\:flex-row { flex-direction: row; }
  .lg\:w-72 { width: 18rem; }
  .lg\:flex-shrink-0 { flex-shrink: 0; }
  .lg\:max-h-\[70vh\] { max-height: 70vh; }
  .lg\:overflow-y-auto { overflow-y: auto; }
}

