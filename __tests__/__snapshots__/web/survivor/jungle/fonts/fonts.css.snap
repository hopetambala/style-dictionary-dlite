/* Fraunces font faces */
@font-face {
  font-family: 'Fraunces';
  src: url('../../fonts/Fraunces-Regular.woff2') format('woff2');
  font-weight: 400;
  font-style: normal;
}

@font-face {
  font-family: 'Fraunces';
  src: url('../../fonts/Fraunces-Bold.woff2') format('woff2');
  font-weight: 700;
  font-style: normal;
}
